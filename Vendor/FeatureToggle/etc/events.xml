<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
 xsi:noNamespaceSchemaLocation="urn:magento:framework/Event/etc/events.xsd">

    <!-- Product Load -->
    <event name="catalog_product_load_after">
        <observer name="vendor_featuretoggle_product_load"
                  instance="Vendor\FeatureToggle\Observer\ProductLoadObserver"/>
    </event>

    <!-- Customer Login -->
    <event name="customer_login">
        <observer name="vendor_featuretoggle_customer_login"
                  instance="Vendor\FeatureToggle\Observer\CustomerLoginObserver"/>
    </event>

    <!-- Order Place -->
    <event name="sales_order_place_after">
        <observer name="vendor_featuretoggle_order_place"
                  instance="Vendor\FeatureToggle\Observer\OrderPlaceObserver"/>
    </event>

</config>