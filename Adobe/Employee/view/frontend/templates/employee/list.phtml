/** @var \Adobe\Employee\Block\Form $block */
$employees = $block->getEmployees();
?>

<div style="margin-bottom: 20px;">
    <a href="<?= $block->getUrl('employee/account/add') ?>"
       style="background:#1979c3;color:#fff;padding:10px 15px;text-decoration:none;border-radius:4px;">
        + Add Employee
    </a>
</div>

<!-- Header -->
<div style="display:grid; grid-template-columns: 50px 150px 130px 180px 150px 100px 200px 120px; font-weight:bold; border-bottom:2px solid #000; padding:10px 0;">
    <div>ID</div>
    <div>Name</div>
    <div>Joining Date</div>
    <div>Designation</div>
    <div>Address</div>
    <div>Status</div>
    <div>Hobbies</div>
    <div>Actions</div>
</div>

<?php if ($employees && count($employees)): ?>
    
    <?php foreach ($employees as $employee): ?>
        
        <div style="display:grid; grid-template-columns: 50px 150px 130px 180px 150px 100px 200px 120px; padding:10px 0; border-bottom:1px solid #ddd;">

            <div><?= (int)$employee->getId() ?></div>

            <div><?= htmlspecialchars((string)$employee->getName()) ?></div>

            <div><?= htmlspecialchars((string)$employee->getJoiningDate()) ?></div>

            <div><?= htmlspecialchars((string)$employee->getDesignation()) ?></div>

            <div><?= htmlspecialchars((string)$employee->getAddress()) ?></div>

            <div><?= $employee->getStatus() ? 'Active' : 'Inactive' ?></div>

            <div>
                <?php
                $hobbies = $employee->getHobbies();

                if (is_string($hobbies)) {
                    $hobbies = json_decode($hobbies, true);
                }

                $hobbies = is_array($hobbies)
                    ? array_filter(array_map('trim', $hobbies))
                    : [];
                ?>

                <?= htmlspecialchars(implode(', ', $hobbies)) ?>
            </div>

            <div>
                <a href="<?= $block->getUrl('employee/account/edit', ['id' => $employee->getId()]) ?>">Edit</a>
                |
                <a href="<?= $block->getUrl('employee/account/delete', ['id' => $employee->getId()]) ?>"
                   onclick="return confirm('Delete this employee?')">Delete</a>
            </div>

        </div>

    <?php endforeach; ?>

<?php else: ?>
    <div style="padding:10px;">No Employees Found</div>
<?php endif; ?>
