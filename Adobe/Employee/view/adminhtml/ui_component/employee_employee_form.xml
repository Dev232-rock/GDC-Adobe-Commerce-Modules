<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">

    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">employee_employee_form.employee_employee_form_data_source</item>
            <item name="deps" xsi:type="string">employee_employee_form.employee_employee_form_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">Employee Form</item>
        <item name="template" xsi:type="string">templates/form/collapsible</item>
    </argument>

    <settings>
        <namespace>employee_employee_form</namespace>
        <dataScope>data</dataScope>
        <deps>
            <dep>employee_employee_form.employee_employee_form_data_source</dep>
        </deps>
        <buttons>
            <button name="back" class="Adobe\Employee\Block\Adminhtml\Employee\Edit\BackButton"/>
            <button name="save" class="Adobe\Employee\Block\Adminhtml\Employee\Edit\SaveButton"/>
        </buttons>
    </settings>

    <dataSource name="employee_employee_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>

        <settings>
            <submitUrl path="employee/employee/save"/>
        </settings>

        <dataProvider class="Adobe\Employee\Model\Employee\DataProvider"
                      name="employee_employee_form_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>entity_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <fieldset name="general">
        <settings>
            <label translate="true">Employee Details</label>
        </settings>

        <field name="name" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Name</label>
                <dataScope>name</dataScope>
            </settings>
        </field>

        <field name="designation" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Designation</label>
                <dataScope>designation</dataScope>
            </settings>
        </field>

        <field name="address" formElement="textarea">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Address</label>
                <dataScope>address</dataScope>
            </settings>
        </field>

        <field name="hobbies" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Hobbies</label>
                <dataScope>hobbies</dataScope>
            </settings>
        </field>

        <field name="status" formElement="select">
            <settings>
                <dataType>number</dataType>
                <label translate="true">Status</label>
                <dataScope>status</dataScope>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Adobe\Employee\Model\Source\Status"/>
                    </settings>
                </select>
            </formElements>
        </field>

    </fieldset>
</form>
